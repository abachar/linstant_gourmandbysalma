{
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2022",
    "skipLibCheck": true,
    "strictNullChecks": true,
    "baseUrl": "./",
    "paths": {
      "@components": ["src/components"],
      "@shared/*": ["src/shared/*"],
      "@routes/*": ["src/routes/*"],
    },
  },
}
