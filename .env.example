# Database URL for PostgreSQL
DATABASE_URL="postgresql://USERNAME:PASSWORD@localhost:5432/DB_NAME"

# App password hash (scrypt) — generate with: node -e "const {scrypt,randomBytes}=require('crypto'),{promisify}=require('util'),s=promisify(scrypt),salt=randomBytes(16).toString('hex');s('YOUR_PASSWORD',salt,64).then(h=>console.log(salt+':'+h.toString('hex')))"
APP_PASSWORD=YOUR_PASSWORD_HASHED

# Generate a secret key: `pnpm dlx auth@latest secret`
