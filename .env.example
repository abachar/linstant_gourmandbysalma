# Database URL for PostgreSQL
DATABASE_URL="postgresql://DB_USERNAME:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME"

# Generate an app password: node -e "const {scrypt,randomBytes}=require('crypto'),{promisify}=require('util'),s=promisify(scrypt),salt=randomBytes(16).toString('hex');s('YOUR_PASSWORD',salt,64).then(h=>console.log(salt+':'+h.toString('hex')))"
APP_PASSWORD_HEX=YOUR_PASSWORD_HASHED

# Generate a secret key: pnpm dlx auth@latest secret
SESSION_SECRET_HEX=YOUR_GENERATED_SECRET
