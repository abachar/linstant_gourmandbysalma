# Database URL for PostgreSQL
DATABASE_URL="postgresql://DB_USERNAME:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME"

# Generate an app password: bun -e "console.log(Buffer.from(await Bun.password.hash('YOUR_PASSWORD')).toString('hex'))"
APP_PASSWORD_HEX=YOUR_PASSWORD_HASHED

# Generate a secret key: bunx auth@latest secret
SESSION_SECRET_HEX=YOUR_GENERATED_SECRET
